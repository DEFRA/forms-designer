{% extends "layouts/forms-website.njk" %}
{% from "masthead/macro.njk" import appMasthead %}

{% block beforeContent %}
  {{ appMasthead(masthead) }}
{% endblock -%}

{% block content %}
<div>
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <div class="app-prose-scope">
          <p>
            Plan your form before you start using the Defra Form Designer.
          </p>
          <p>
            Planning helps you to:
          </p>
            <ul>
              <li>show the user's journey clearly </li>
              <li>decide where grouping makes sense</li>
              <li>reduce unnecessary pages </li>
              <li>avoid redundant questions </li>
              <li>talk through the form with SMEs and stakeholders </li>
            </ul>
        <p>
          You can do this in software like Viso, Mural or using pen and paper.
        </p>
        <p>
          <a href="">See an example form plan with conditions</a>.
        </p>
      <h2>Avoid duplicating questions</h2>
        <p>
          Reducing duplicate questions improves efficiency and the user experience.
        </p>
        <p>
          Avoid duplication by:
        </p>
        <ul>
              <li>only asking for information once </li>
              <li>reusing data across different steps </li>
              <li>removing optional fields unless critical </li>
        </ul>
      <h2>Send your plan to the Defra Forms team</h2>
        <p>
           We will review your plan to ensure the structure of your form meets the GOV.UK service standards. For example, by placing eligibility questions at the start of the form.
        </p>
        <p>
          When your plan is ready for review, send it by email to: <a href="mailto:defraforms@defra.gov.uk">defraforms@defra.gov.uk</a>
        </p>
</div>
      </div>
    </div>
</div>
</div>
{% endblock %}
