{% extends "layouts/forms-website.njk" %}
{% from "masthead/macro.njk" import appMasthead %}

{% block beforeContent %}
  {{ appMasthead(masthead) }}
{% endblock -%}

{% block content %}
<div>
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <div class="app-prose-scope">
          <p>
            You cannot publish a form on GOV.UK using the Defra Form Designer without at least one alternative contact method.
          </p>
          <p>
            Providing an alternative contact method is also known as providing ‘assisted digital support’.
          </p>
          <p>
            You can provide assisted digital support:
          </p>
          <ul>
            <li>in person</li>
            <li>on the telephone</li>
            <li>via webchat</li>
          </ul>
          <p>
            You should give users information about assisted digital support via:
          </p>
          <ul>
            <li>your online service - for example on a GOV.UK start page or within your form</li>
            <li>other communications - letters, emails, posters, leaflets, social media</li>
          </ul>
          <p>
            Read more about <a href="https://www.gov.uk/service-manual/helping-people-to-use-your-service/assisted-digital-support-introduction">providing assisted digital support</a>.
          </p>
</div>
      </div>
    </div>
</div>
</div>
{% endblock %}
