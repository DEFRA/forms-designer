<table class="govuk-table">
    <thead class="govuk-table__head">
      <tr class="govuk-table__row">
        <th scope="col" class="govuk-table__header">Metric</th>
        <th scope="col" class="govuk-table__header">Average (draft)</th>
        <th scope="col" class="govuk-table__header">Minimum (draft)</th>
        <th scope="col" class="govuk-table__header">Maximum (draft)</th>
        <th scope="col" class="govuk-table__header">Average (live)</th>
        <th scope="col" class="govuk-table__header">Minimum (live)</th>
        <th scope="col" class="govuk-table__header">Maximum (live)</th>
      </tr>
    </thead>
    <tbody class="govuk-table__body">
      {% for row in model.formUsageFormStructures %}
      <tr class="govuk-table__row">
        <td class="govuk-table__cell">{{ row.metricName }}</td>
        <td class="govuk-table__cell">{{ row.draft.average }}</td>
        <td class="govuk-table__cell">{{ row.draft.minimum | formatNumber }}</td>
        <td class="govuk-table__cell">{{ row.draft.maximum | formatNumber }}</td>
        <td class="govuk-table__cell">{{ row.live.average }}</td>
        <td class="govuk-table__cell">{{ row.live.minimum | formatNumber }}</td>
        <td class="govuk-table__cell">{{ row.live.maximum | formatNumber }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
