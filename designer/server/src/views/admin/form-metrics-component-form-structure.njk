<table class="govuk-table">
    <thead class="govuk-table__head">
      <tr class="govuk-table__row">
        <th scope="col" class="govuk-table__header">Metric</th>
        <th scope="col" class="govuk-table__header">Average</th>
        <th scope="col" class="govuk-table__header">Minimum</th>
        <th scope="col" class="govuk-table__header">Maximum</th>
      </tr>
    </thead>
    <tbody class="govuk-table__body">
      {% for row in model.formUsageFormStructures %}
      <tr class="govuk-table__row">
        <td class="govuk-table__cell">{{ row.metricName }}</td>
        <td class="govuk-table__cell">{{ row.average }}</td>
        <td class="govuk-table__cell">{{ row.minimum | formatNumber }}</td>
        <td class="govuk-table__cell">{{ row.maximum | formatNumber }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
