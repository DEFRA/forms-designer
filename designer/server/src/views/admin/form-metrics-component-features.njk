<table class="govuk-table">
    <thead class="govuk-table__head">
      <tr class="govuk-table__row">
        <th scope="col" class="govuk-table__header"></th>
        <th scope="col" colspan="2" class="govuk-table__header govuk-tag--yellow pull-center"><strong class="govuk-tag govuk-tag--yellow">Draft</strong></th>
        <th scope="col" colspan="2" class="govuk-table__header govuk-tag--green pull-center"><strong class="govuk-tag govuk-tag--green">Live</strong></th>
      </tr>
      <tr class="govuk-table__row">
        <th scope="col" class="govuk-table__header">Feature</th>
        <th scope="col" class="govuk-table__header">Forms using (draft)</th>
        <th scope="col" class="govuk-table__header">Percentage (draft)</th>
        <th scope="col" class="govuk-table__header">Forms using (live)</th>
        <th scope="col" class="govuk-table__header">Percentage (live)</th>
      </tr>
    </thead>
    <tbody class="govuk-table__body">
      {% for row in model.formUsageFeatures %}
      <tr class="govuk-table__row">
        <td class="govuk-table__cell">{{ row.featureName }}</td>
        <td class="govuk-table__cell">{{ displayMetricValue(row.draft.formsUsing) }}</td>
        <td class="govuk-table__cell">{{ displayMetricPercent(row.draft.percentage) }}</td>
        <td class="govuk-table__cell">{{ displayMetricValue(row.live.formsUsing) }}</td>
        <td class="govuk-table__cell">{{ displayMetricPercent(row.live.percentage) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
