{% extends "layouts/page.njk" %}

{% from "page-body/macro.njk" import appPageBody %}

{% set mainClasses = "govuk-main-wrapper--masthead" %}

{% block content %}
  {% call appPageBody({
    heading: pageHeading,
    useNewMasthead: true,
    classes: "govuk-grid-column-full",
    backLink: backLink
  }) %}

    <div class="govuk-tabs">
      <ul class="govuk-tabs__list">
        {% for tab in tabItems %}
          <li class="govuk-tabs__list-item{% if tab.active %} govuk-tabs__list-item--selected{% endif %}">
            <a class="govuk-tabs__tab" href="{{ tab.href }}">{{ tab.label }}</a>
          </li>
        {% endfor %}
      </ul>

      <div class="govuk-tabs__panel">
        <h2 class="govuk-heading-m">Version {{ versionA }} &rarr; Version {{ versionB }}</h2>

        <p class="govuk-body">
          <a class="govuk-link" href="/admin/form-inspect/{{ formId }}/versions/{{ versionA }}">View version {{ versionA }}</a>
          &nbsp;&middot;&nbsp;
          <a class="govuk-link" href="/admin/form-inspect/{{ formId }}/versions/{{ versionB }}">View version {{ versionB }}</a>
        </p>

        <div id="version-diff-output" class="json-item">
          <noscript>
            <p class="govuk-body">JavaScript is required to render the diff.</p>
          </noscript>
        </div>

        <script type="application/json" id="version-diff-a">{{ definitionA | dump | replace("</", "<\\/") | safe }}</script>
        <script type="application/json" id="version-diff-b">{{ definitionB | dump | replace("</", "<\\/") | safe }}</script>
      </div>
    </div>

  {% endcall %}
{% endblock %}

{% block mainEnd %}
  {{ super() }}
  <script type="module">
    import { renderVersionDiff } from "{{ getAssetPath("form-inspect-version-diff-detail.js") }}"
    document.addEventListener("DOMContentLoaded", () => {
      const container = document.getElementById("version-diff-output")
      const rawA = document.getElementById("version-diff-a")?.textContent ?? "null"
      const rawB = document.getElementById("version-diff-b")?.textContent ?? "null"
      renderVersionDiff(container, JSON.parse(rawA), JSON.parse(rawB))
    })
  </script>
{% endblock %}
