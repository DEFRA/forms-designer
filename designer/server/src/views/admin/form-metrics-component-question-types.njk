<table class="govuk-table">
    <thead class="govuk-table__head">
      <tr class="govuk-table__row">
        <th scope="col" class="govuk-table__header"></th>
        <th scope="col" colspan="3" class="govuk-table__header govuk-tag--yellow pull-center"><strong class="govuk-tag govuk-tag--yellow">Draft</strong></th>
        <th scope="col" colspan="3" class="govuk-table__header govuk-tag--green pull-center"><strong class="govuk-tag govuk-tag--green">Live</strong></th>
      </tr>
      <tr class="govuk-table__row">
        <th scope="col" class="govuk-table__header">Question type</th>
        <th scope="col" class="govuk-table__header">Total usage</th>
        <th scope="col" class="govuk-table__header">Forms using</th>
        <th scope="col" class="govuk-table__header">Percentage</th>
        <th scope="col" class="govuk-table__header">Total usage</th>
        <th scope="col" class="govuk-table__header">Forms using</th>
        <th scope="col" class="govuk-table__header">Percentage</th>
      </tr>
    </thead>
    <tbody class="govuk-table__body">
      {% for row in model.formUsageQuestionTypes %}
      <tr class="govuk-table__row">
        <td class="govuk-table__cell">{{ row.questionTypeName }}</td>
        <td class="govuk-table__cell">{{ displayMetricValue(row.draft.totalUsage) }}</td>
        <td class="govuk-table__cell">{{ displayMetricValue(row.draft.formsUsing) }}</td>
        <td class="govuk-table__cell">{{ displayMetricPercent(row.draft.percentage) }}</td>
        <td class="govuk-table__cell">{{ displayMetricValue(row.live.totalUsage) }}</td>
        <td class="govuk-table__cell">{{ displayMetricValue(row.live.formsUsing) }}</td>
        <td class="govuk-table__cell">{{ displayMetricPercent(row.live.percentage) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
